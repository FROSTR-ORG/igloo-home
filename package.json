{
  "name": "igloo-home",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare:workspace": "bash ../../scripts/test-prebuild.sh ensure ui",
    "prepare:e2e": "bash ../../scripts/test-prebuild.sh ensure home demo",
    "build:ui": "npm --prefix ../igloo-ui run build",
    "build:app": "tsc && vite build && node ./scripts/check-built-css.mjs",
    "dev:raw": "vite --host 0.0.0.0 --port 1420 --strictPort",
    "dev": "npm run prepare:workspace && npm run dev:raw",
    "build": "npm run prepare:workspace && npm run build:app",
    "typecheck:raw": "tsc --noEmit",
    "typecheck": "npm run prepare:workspace && npm run typecheck:raw",
    "test:unit:raw": "vitest run",
    "test:unit": "npm run prepare:workspace && npm run test:unit:raw",
    "test:desktop": "npm run prepare:workspace && node ./test/desktop/run.mjs",
    "test:desktop:xvfb": "npm run prepare:workspace && bash ./scripts/run-desktop-xvfb.sh",
    "test:visual": "npm run prepare:workspace && node ./test/visual/run.mjs",
    "test": "npm run typecheck && npm run test:unit:raw",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.0.0",
    "igloo-ui": "file:../igloo-ui",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.1.0",
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.8",
    "vitest": "^2.1.3"
  }
}
