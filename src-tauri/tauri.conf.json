{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Igloo Home",
  "version": "0.1.0",
  "identifier": "org.frostr.igloo-home",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Igloo Home",
        "width": 1440,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 820,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "FROSTR V2 desktop co-signer and share manager"
  }
}

